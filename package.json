{
  "name": "@librestock/api",
  "version": "0.0.1",
  "description": "LibreStock Inventory API",
  "author": "",
  "private": true,
  "license": "AGPL-3.0",
  "scripts": {
    "build": "bun build src/effect/main.ts --outdir dist/effect --target bun",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/effect/main.ts",
    "start:prod": "NODE_ENV=production bun dist/effect/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "import:sortly": "bun run src/scripts/import-sortly.ts",
    "seed": "bun run src/scripts/seed-database.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/schema": "^0.75.5",
    "@librestock/types": "workspace:*",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "better-auth": "1.5.6",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.21.0",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@faker-js/faker": "^10.4.0",
    "@librestock/eslint-config": "workspace:*",
    "@librestock/tsconfig": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.20.0",
    "eslint": "^10.1.0",
    "eslint-import-resolver-node": "^0.3.9",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "unrs-resolver"
  ]
}
