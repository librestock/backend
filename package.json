{
  "name": "@librestock/api",
  "version": "0.0.1",
  "description": "LibreStock Inventory API",
  "author": "",
  "private": true,
  "scripts": {
    "build": "bun build src/effect/main.ts --outdir dist/effect --target bun",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/effect/main.ts",
    "start:prod": "NODE_ENV=production bun dist/effect/main.js",
    "lint": "oxlint src test",
    "lint:fix": "oxlint --fix src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "import:sortly": "bun run src/scripts/import-sortly.ts",
    "seed": "bun run src/scripts/seed-database.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/cluster": "^0.58.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/rpc": "^0.75.0",
    "@effect/sql": "^0.51.0",
    "@librestock/types": "workspace:*",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "better-auth": "1.5.6",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.21.0",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@faker-js/faker": "^10.4.0",
    "@librestock/tsconfig": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "oxlint": "^1.17.0",
    "vitest": "^4.1.2"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "unrs-resolver"
  ]
}
