{
  "name": "@librestock/api",
  "version": "0.0.1",
  "description": "LibreStock Inventory API",
  "author": "",
  "private": true,
  "license": "AGPL-3.0",
  "scripts": {
    "build": "bun build src/effect/main.ts --outdir dist/effect --target bun",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/effect/main.ts",
    "start:prod": "NODE_ENV=production bun dist/effect/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "import:sortly": "ts-node -r tsconfig-paths/register src/scripts/import-sortly.ts",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed-database.ts",
    "type-check": "tsc --noEmit",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/typeorm-cli.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/typeorm-cli.config.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/typeorm-cli.config.ts"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/schema": "^0.75.5",
    "@librestock/types": "1.4.0",
    "better-auth": "1.5.6",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.21.0",
    "pg": "^8.20.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@faker-js/faker": "^10.4.0",
    "@librestock/eslint-config": "1.1.5",
    "@librestock/tsconfig": "1.1.5",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.20.0",
    "eslint": "^10.1.0",
    "eslint-import-resolver-node": "^0.3.9",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": ["/node_modules/", "\\.effect\\.spec\\.ts$"],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "\\.entity\\.ts$",
      "main\\.ts$",
      "/test-utils/",
      "/scripts/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "unrs-resolver"
  ]
}
